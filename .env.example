# ── ConnectHub Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker-compose up

# JWT secret — MUST be at least 256 bits (base64 encoded). Change this in production!
JWT_SECRET=fUfwkEaeomu7puBOIl0ftR50UPF4CBPUDxZ0lcaGXL2hY3Zai4DS4YO7l4902IJsKVdHyNjdpCL4LX7IGkw2qg==

# MySQL — matches the user created by init-databases.sql
MYSQL_HOST=mysql
MYSQL_USER=parents
MYSQL_PASSWORD=parents@top

# Redis
REDIS_HOST=redis

# Eureka (service discovery)
EUREKA_HOST=service-registry

# AWS S3 (optional — media-service falls back to local filesystem if not configured)
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_S3_BUCKET=connecthub-media
AWS_REGION=us-east-1

# Email / SMTP (for OTP emails)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# OAuth2 (register apps at console.developers.google.com and github.com/settings/developers)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Frontend URL (used for OAuth2 redirect after login)
FRONTEND_URL=http://localhost:3000
